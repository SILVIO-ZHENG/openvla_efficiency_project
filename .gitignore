# 中文：Python 缓存文件
# English: Python cache files
__pycache__/
*.py[cod]
*.pyo

# 中文：虚拟环境
# English: Virtual environments
.venv/
venv/
env/

# 中文：PyCharm / IntelliJ 本地配置
# English: PyCharm / IntelliJ local settings
.idea/

# 中文：系统临时文件
# English: System temporary files
.DS_Store
Thumbs.db

# 中文：环境变量文件，不上传账号、路径、token
# English: Environment files, do not upload accounts, paths, or tokens
.env
.env.*

# 中文：Jupyter 临时检查点
# English: Jupyter temporary checkpoints
.ipynb_checkpoints/

# 中文：大型数据文件不要上传到 GitHub
# English: Do not upload large dataset files to GitHub
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# 中文：模型权重和 checkpoint 不上传
# English: Do not upload model weights and checkpoints
*.pt
*.pth
*.ckpt
*.safetensors
checkpoints/
models/
weights/

# 中文：实验输出一般不上传，除非是小的最终表格或图
# English: Do not upload large experiment outputs, except small final tables or figures
results/logs/*
results/tmp/*
wandb/
runs/
mlruns/

# 中文：GPU / HPC 作业输出文件
# English: GPU / HPC job output files
*.out
*.err
slurm-*.out

# 中文：压缩包和大型二进制文件
# English: Archives and large binary files
*.zip
*.tar
*.tar.gz
*.7z
*.rar